doctype html
html(lang="en")
  head
    title Album Manager
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
  body
    .container.mt-4
      nav.mb-4.d-flex.align-items-center
        a.text-decoration-none(href="/") Home
        span.mx-2  | 
        a.text-decoration-none(href="/albums") List Albums
        span.mx-2  | 
        a.text-decoration-none(href="/add-album") Add Album
        span.mx-2 | 
        form(action="/api/auth/logout" method="POST" style="display: inline;")
          button.btn.btn-link.p-0.mb-1.text-decoration-none(type="submit" style="vertical-align: baseline;") Logout
      block content
